<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="csrf-token" content="<%= form_authenticity_token %>">
  <title>Login — Repair Tracker</title>
  <link rel="stylesheet" href="<%= asset_path 'login.css' %>">
</head>
<body>

  <div class="box">
    <h1>Repair Tracker</h1>

    <!-- error message box hidden til needed -->
    <div class="error" id="error-box">Wrong email or password</div>

    <label>Email</label>
    <input type="email" id="email" placeholder="customer@test.com">

    <label>Password</label>
    <input type="password" id="password" placeholder="password123">

    <button onclick="login()">Login</button>
  </div>

  <script src="<%= asset_path 'login.js' %>"></script>

</body>
</html>